const EXPERIENCE_LEVEL_STYLES: Record<string, string> = {
  Fresher: 'bg-green-500/20 text-green-400 border-green-500/30',
  Junior: 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  'Mid-Level': 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30',
  Senior: 'bg-orange-500/20 text-orange-400 border-orange-500/30',
  'Lead/Architect': 'bg-purple-500/20 text-purple-400 border-purple-500/30',
};

const EMPTY_RESUME: ResumeData = {
  fullName: '',
  email: '',
  phone: '',
  location: '',
  linkedin: '',
  github: '',
  portfolio: '',
  professionalSummary: '',
  technicalSkills: '',
  softSkills: '',
  experiences: [{ company: '', role: '', duration: '', responsibilities: '' }],
  projects: [{ name: '', description: '', technologies: '' }],
  educations: [{ degree: '', institute: '', year: '', gpa: '' }],
  certifications: '',
  jobDescription: '',
};

// ─────────────────── Component ───────────────────

const ResumeBuilder: React.FC = () => {
  const [step, setStep] = useState<Step>('position-select');
  const [selectedPosition, setSelectedPosition] = useState<Position | null>(null);
  const [formData, setFormData] = useState<ResumeData>(EMPTY_RESUME);
  const [activeSection, setActiveSection] = useState<string>('personal');
  const [atsScore, setAtsScore] = useState<ATSScore | null>(null);
  const [isCalculating, setIsCalculating] = useState(false);
  const [isDownloading, setIsDownloading] = useState(false);

  const templates = selectedPosition === 'java-developer' ? JAVA_TEMPLATES : DOTNET_TEMPLATES;

  // ── Handlers ──

  const handleSelectPosition = (pos: Position) => {
    setSelectedPosition(pos);
    setStep('template-select');
  };

  const handleSelectTemplate = (template: TemplateCard) => {
    setFormData(template.data);
    setAtsScore(null);
    setActiveSection('personal');
    setStep('editor');
  };

  const handleBackToPositions = () => {
    setStep('position-select');
    setSelectedPosition(null);
  };

  const handleBackToTemplates = () => {
    setStep('template-select');
    setAtsScore(null);
  };

  // Experience
  const addExperience = () =>
    setFormData({ ...formData, experiences: [...formData.experiences, { company: '', role: '', duration: '', responsibilities: '' }] });

  const removeExperience = (i: number) =>
    setFormData({ ...formData, experiences: formData.experiences.filter((_, idx) => idx !== i) });

  const updateExperience = (i: number, field: keyof Experience, val: string) => {
    const arr = [...formData.experiences];
    arr[i] = { ...arr[i], [field]: val };
    setFormData({ ...formData, experiences: arr });
  };

  // Project
  const addProject = () =>
    setFormData({ ...formData, projects: [...formData.projects, { name: '', description: '', technologies: '' }] });

  const removeProject = (i: number) =>
    setFormData({ ...formData, projects: formData.projects.filter((_, idx) => idx !== i) });

  const updateProject = (i: number, field: keyof Project, val: string) => {
    const arr = [...formData.projects];
    arr[i] = { ...arr[i], [field]: val };
    setFormData({ ...formData, projects: arr });
  };

  // Education
  const addEducation = () =>
    setFormData({ ...formData, educations: [...formData.educations, { degree: '', institute: '', year: '', gpa: '' }] });

  const removeEducation = (i: number) =>
    setFormData({ ...formData, educations: formData.educations.filter((_, idx) => idx !== i) });

  const updateEducation = (i: number, field: keyof Education, val: string) => {
    const arr = [...formData.educations];
    arr[i] = { ...arr[i], [field]: val };
    setFormData({ ...formData, educations: arr });
  };

  // ATS Score
  const calculateATSScore = (): ATSScore => {
    const jd = formData.jobDescription.toLowerCase();
    const skills = `${formData.technicalSkills} ${formData.softSkills}`.toLowerCase();
    const summary = formData.professionalSummary.toLowerCase();
    const allExp = formData.experiences.map((e) => `${e.role} ${e.responsibilities}`).join(' ').toLowerCase();
    const allProj = formData.projects.map((p) => `${p.name} ${p.description} ${p.technologies}`).join(' ').toLowerCase();
    const resumeContent = `${skills} ${summary} ${allExp} ${allProj}`;
    const stopWords = new Set(['with', 'this', 'that', 'will', 'have', 'been', 'from', 'into', 'should', 'work', 'team', 'must']);
    const jdWords = [...new Set(jd.split(/\W+/).filter((w) => w.length > 3 && !stopWords.has(w)))];
    const matchedKw = jdWords.filter((w) => resumeContent.includes(w));
    const kwScore = jdWords.length > 0 ? Math.round((matchedKw.length / jdWords.length) * 40) : 0;
    const skillsList = skills.split(',').map((s) => s.trim());
    const matchedSkills = skillsList.filter((s) => jd.includes(s));
    const skillScore = skillsList.length > 0 ? Math.round((matchedSkills.length / skillsList.length) * 30) : 0;
    const expScore = formData.experiences.some((e) => e.company && e.role && e.responsibilities) ? 20 : 0;
    return { total: kwScore + skillScore + expScore + 10, keywordsMatch: kwScore, skillsAlignment: skillScore, experienceAlignment: expScore, formatting: 10 };
  };

  const handleCalculateATS = () => {
    setIsCalculating(true);
    setTimeout(() => {
      setAtsScore(calculateATSScore());
      setIsCalculating(false);
    }, 800);
  };

  // PDF Download
  const downloadPDF = () => {
    setIsDownloading(true);
    setTimeout(() => {
      const doc = new jsPDF();
      const pw = doc.internal.pageSize.getWidth();
      const ph = doc.internal.pageSize.getHeight();
      const m = 20;
      let y = 20;

      const pageBreak = (space = 20) => { if (y + space > ph - 20) { doc.addPage(); y = 20; } };
      const addText = (text: string, size = 11, bold = false) => {
        pageBreak();
        doc.setFontSize(size);
        doc.setFont('helvetica', bold ? 'bold' : 'normal');
        const lines = doc.splitTextToSize(text, pw - 2 * m);
        doc.text(lines, m, y);
        y += lines.length * (size * 0.35) + 3;
      };
      const addSection = (title: string) => {
        pageBreak(15);
        y += 5;
        doc.setFontSize(13);
        doc.setFont('helvetica', 'bold');
        doc.text(title, m, y);
        y += 2;
        doc.setLineWidth(0.5);
        doc.line(m, y, pw - m, y);
        y += 5;
      };

      doc.setFontSize(18); doc.setFont('helvetica', 'bold');
      doc.text(formData.fullName, pw / 2, y, { align: 'center' }); y += 7;
      doc.setFontSize(10); doc.setFont('helvetica', 'normal');
      doc.text(`${formData.email} | ${formData.phone} | ${formData.location}`, pw / 2, y, { align: 'center' }); y += 5;
      const links = [formData.linkedin, formData.github, formData.portfolio].filter(Boolean);
      if (links.length) { doc.text(links.join(' | '), pw / 2, y, { align: 'center' }); y += 8; } else { y += 3; }

      if (formData.professionalSummary) { addSection('PROFESSIONAL SUMMARY'); addText(formData.professionalSummary); }
      if (formData.technicalSkills) { addSection('TECHNICAL SKILLS'); addText(formData.technicalSkills); }
      if (formData.softSkills) { addSection('SOFT SKILLS'); addText(formData.softSkills); }
      if (formData.experiences.some((e) => e.company)) {
        addSection('PROFESSIONAL EXPERIENCE');
        formData.experiences.forEach((exp) => {
          if (!exp.company) return;
          pageBreak(25);
          addText(`${exp.role} at ${exp.company}`, 11, true);
          if (exp.duration) { doc.setFontSize(10); doc.setFont('helvetica', 'italic'); doc.text(exp.duration, m, y); y += 5; }
          if (exp.responsibilities) exp.responsibilities.split('\n').filter(Boolean).forEach((b) => addText(`• ${b.trim()}`, 10));
          y += 3;
        });
      }
      if (formData.projects.some((p) => p.name)) {
        addSection('PROJECTS');
        formData.projects.forEach((proj) => {
          if (!proj.name) return;
          pageBreak(20);
          addText(proj.name, 11, true);
          if (proj.description) addText(proj.description, 10);
          if (proj.technologies) { doc.setFont('helvetica', 'italic'); addText(`Technologies: ${proj.technologies}`, 9); }
          y += 2;
        });
      }
      if (formData.educations.some((e) => e.degree)) {
        addSection('EDUCATION');
        formData.educations.forEach((edu) => {
          if (!edu.degree) return;
          pageBreak(10);
          addText(`${edu.degree} – ${edu.institute} (${edu.year})`, 11, true);
          if (edu.gpa) addText(`GPA: ${edu.gpa}`, 10);
        });
      }
      if (formData.certifications) { addSection('CERTIFICATIONS'); addText(formData.certifications); }

      doc.save(`${formData.fullName.replace(/\s+/g, '_') || 'Resume'}_Resume.pdf`);
      setIsDownloading(false);
    }, 100);
  };

  const getScoreColor = (s: number) => (s >= 70 ? 'text-green-500' : s >= 50 ? 'text-yellow-500' : 'text-red-500');

  // ── Section toggle helper ──
  const toggleSection = (id: string) => setActiveSection(activeSection === id ? '' : id);

  // ─────────────────── STEP 1: Position Select ───────────────────
  if (step === 'position-select') {
    return (
      <div className="space-y-8">
        <div>
          <h2 className="text-2xl font-bold text-white flex items-center gap-2">
            <FileUser className="w-7 h-7 text-neon-blue" />
            ATS Resume Builder
          </h2>
          <p className="text-gray-400 mt-1">Build a professional, ATS-optimised resume in minutes</p>
        </div>

        <div className="bg-dark-800 border border-white/10 rounded-xl p-8">
          <h3 className="text-lg font-semibold text-white mb-2 flex items-center gap-2">
            <Sparkles className="w-5 h-5 text-neon-purple" />
            Step 1 of 3 — Select Your Job Position
          </h3>
          <p className="text-gray-400 text-sm mb-8">
            Choose your target job position. We'll show you 10 ready-made resume templates tailored for that role.
          </p>

          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
            {/* Java Developer */}
            <button
              onClick={() => handleSelectPosition('java-developer')}
              className="group p-8 bg-dark-900 border-2 border-white/10 rounded-xl hover:border-neon-blue hover:bg-neon-blue/5 transition-all text-left"
            >
              <div className="flex items-center gap-4 mb-4">
                <div className="w-14 h-14 rounded-xl bg-neon-blue/10 border border-neon-blue/20 flex items-center justify-center group-hover:bg-neon-blue/20 transition-colors">
                  <Coffee className="w-7 h-7 text-neon-blue" />
                </div>
                <div>
                  <h4 className="text-xl font-bold text-white">Java Developer</h4>
                  <p className="text-neon-blue text-sm font-medium">10 templates available</p>
                </div>
              </div>
              <p className="text-gray-400 text-sm mb-4">
                Templates for Java, Spring Boot, Microservices, Cloud, and leadership roles — from fresher to architect.
              </p>
              <div className="flex flex-wrap gap-2">
                {['Spring Boot', 'Microservices', 'Cloud', 'Full Stack', 'Tech Lead'].map((tag) => (
                  <span key={tag} className="px-2 py-1 bg-neon-blue/10 text-neon-blue text-xs rounded-md border border-neon-blue/20">
                    {tag}
                  </span>
                ))}
              </div>
            </button>

            {/* .NET Developer */}
            <button
              onClick={() => handleSelectPosition('dotnet-developer')}
              className="group p-8 bg-dark-900 border-2 border-white/10 rounded-xl hover:border-neon-purple hover:bg-neon-purple/5 transition-all text-left"
            >
              <div className="flex items-center gap-4 mb-4">
                <div className="w-14 h-14 rounded-xl bg-neon-purple/10 border border-neon-purple/20 flex items-center justify-center group-hover:bg-neon-purple/20 transition-colors">
                  <Monitor className="w-7 h-7 text-neon-purple" />
                </div>
                <div>
                  <h4 className="text-xl font-bold text-white">.NET Developer</h4>
                  <p className="text-neon-purple text-sm font-medium">10 templates available</p>
                </div>
              </div>
              <p className="text-gray-400 text-sm mb-4">
                Templates for C#, ASP.NET Core, Azure, Microservices, and leadership roles — from fresher to architect.
              </p>
              <div className="flex flex-wrap gap-2">
                {['ASP.NET Core', 'Azure', 'Microservices', 'Full Stack', 'Tech Lead'].map((tag) => (
                  <span key={tag} className="px-2 py-1 bg-neon-purple/10 text-neon-purple text-xs rounded-md border border-neon-purple/20">
                    {tag}
                  </span>
                ))}
              </div>
            </button>
          </div>
        </div>
      </div>
    );
  }

  // ─────────────────── STEP 2: Template Select ───────────────────
  if (step === 'template-select') {
    const accentColor = selectedPosition === 'java-developer' ? 'neon-blue' : 'neon-purple';
    const posLabel = selectedPosition === 'java-developer' ? 'Java Developer' : '.NET Developer';

    return (
      <div className="space-y-6">
        <div className="flex items-center gap-4">
          <button
            onClick={handleBackToPositions}
            className="flex items-center gap-2 px-3 py-2 bg-dark-800 border border-white/10 rounded-lg text-gray-400 hover:text-white hover:border-white/20 transition-colors"
          >
            <ArrowLeft className="w-4 h-4" />
            Back
          </button>
          <div>
            <h2 className="text-2xl font-bold text-white flex items-center gap-2">
              <FileUser className="w-7 h-7 text-neon-blue" />
              ATS Resume Builder
            </h2>
            <p className="text-gray-400 text-sm mt-0.5">Step 2 of 3 — Choose a template for <span className={`text-${accentColor} font-semibold`}>{posLabel}</span></p>
          </div>
        </div>

        <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
          {templates.map((tmpl, idx) => {
            const Icon = tmpl.icon;
            const levelStyle = EXPERIENCE_LEVEL_STYLES[tmpl.experienceLevel] || '';
            return (
              <div
                key={tmpl.id}
                className="relative bg-dark-800 border border-white/10 rounded-xl p-6 flex flex-col hover:border-white/20 transition-all"
              >
                {/* Number badge */}
                <span className="absolute top-4 right-4 w-7 h-7 flex items-center justify-center bg-white/5 rounded-full text-xs text-gray-400 font-semibold border border-white/10">
                  {idx + 1}
                </span>

                <div className="flex items-start gap-3 mb-3">
                  <div className={`w-11 h-11 rounded-lg bg-${accentColor}/10 border border-${accentColor}/20 flex items-center justify-center flex-shrink-0`}>
                    <Icon className={`w-5 h-5 text-${accentColor}`} />
                  </div>
                  <div>
                    <h4 className="text-white font-semibold leading-tight">{tmpl.name}</h4>
                    <span className={`inline-block mt-1 px-2 py-0.5 text-xs rounded-full border ${levelStyle}`}>
                      {tmpl.experienceLevel}
                    </span>
                  </div>
                </div>

                <p className="text-gray-400 text-sm mb-4 flex-1">{tmpl.description}</p>

                {/* Skills preview */}
                <div className="flex flex-wrap gap-1 mb-4">
                  {tmpl.data.technicalSkills
                    .split(',')
                    .slice(0, 4)
                    .map((s) => (
                      <span key={s.trim()} className="px-2 py-0.5 bg-white/5 text-gray-300 text-xs rounded border border-white/10">
                        {s.trim()}
                      </span>
                    ))}
                  {tmpl.data.technicalSkills.split(',').length > 4 && (
                    <span className="px-2 py-0.5 bg-white/5 text-gray-500 text-xs rounded border border-white/10">
                      +{tmpl.data.technicalSkills.split(',').length - 4} more
                    </span>
                  )}
                </div>

                <button
                  onClick={() => handleSelectTemplate(tmpl)}
                  className={`w-full py-2.5 rounded-lg font-semibold text-sm transition-colors bg-${accentColor}/10 text-${accentColor} border border-${accentColor}/20 hover:bg-${accentColor}/20`}
                >
                  Use This Template
                </button>
              </div>
            );
          })}
        </div>
      </div>
    );
  }

  // ─────────────────── STEP 3: Editor ───────────────────

  const sections = [
    { id: 'personal', label: 'Personal Details', icon: User },
    { id: 'summary', label: 'Professional Summary', icon: FileText },
    { id: 'skills', label: 'Skills', icon: Code },
    { id: 'experience', label: 'Experience', icon: Briefcase },
    { id: 'projects', label: 'Projects', icon: Layers },
    { id: 'education', label: 'Education', icon: BookOpen },
    { id: 'certifications', label: 'Certifications', icon: Award },
    { id: 'ats', label: 'ATS Job Description', icon: Sparkles },
  ];

  return (
    <div className="space-y-4">
      {/* Header */}
      <div className="flex items-center justify-between gap-4 flex-wrap">
        <div className="flex items-center gap-4">
          <button
            onClick={handleBackToTemplates}
            className="flex items-center gap-2 px-3 py-2 bg-dark-800 border border-white/10 rounded-lg text-gray-400 hover:text-white hover:border-white/20 transition-colors"
          >
            <ArrowLeft className="w-4 h-4" />
            Back
          </button>
          <div>
            <h2 className="text-xl font-bold text-white flex items-center gap-2">
              <FileUser className="w-6 h-6 text-neon-blue" />
              Edit Your Resume
            </h2>
            <p className="text-gray-400 text-sm">Step 3 of 3 — All changes reflect in real time</p>
          </div>
        </div>
        <button
          onClick={downloadPDF}
          disabled={isDownloading || !formData.fullName}
          className="flex items-center gap-2 px-5 py-2.5 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          {isDownloading ? <Loader2 className="w-4 h-4 animate-spin" /> : <Download className="w-4 h-4" />}
          Download PDF
        </button>
      </div>

      {/* Main editor layout */}
      <div className="grid grid-cols-1 xl:grid-cols-2 gap-6 items-start">

        {/* ── LEFT: Section-wise Editor ── */}
        <div className="space-y-2">
          {sections.map(({ id, label, icon: Icon }) => {
            const isOpen = activeSection === id;
            return (
              <div key={id} className="bg-dark-800 border border-white/10 rounded-xl overflow-hidden">
                <button
                  onClick={() => toggleSection(id)}
                  className="w-full flex items-center justify-between px-5 py-4 text-left hover:bg-white/5 transition-colors"
                >
                  <div className="flex items-center gap-3">
                    <Icon className="w-4 h-4 text-neon-blue" />
                    <span className="text-white font-medium text-sm">{label}</span>
                  </div>
                  {isOpen ? <ChevronUp className="w-4 h-4 text-gray-400" /> : <ChevronDown className="w-4 h-4 text-gray-400" />}
                </button>

                {isOpen && (
                  <div className="px-5 pb-5 border-t border-white/10 pt-4 space-y-4">

                    {/* Personal Details */}
                    {id === 'personal' && (
                      <>
                        <div>
                          <label className="block text-xs font-medium text-gray-400 mb-1.5">Full Name *</label>
                          <input type="text" value={formData.fullName} onChange={(e) => setFormData({ ...formData, fullName: e.target.value })} placeholder="John Doe" className="w-full px-3 py-2 bg-dark-900 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                        </div>
                        <div className="grid grid-cols-2 gap-3">
                          <div>
                            <label className="block text-xs font-medium text-gray-400 mb-1.5">Email *</label>
                            <input type="email" value={formData.email} onChange={(e) => setFormData({ ...formData, email: e.target.value })} placeholder="john@email.com" className="w-full px-3 py-2 bg-dark-900 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                          </div>
                          <div>
                            <label className="block text-xs font-medium text-gray-400 mb-1.5">Phone *</label>
                            <input type="tel" value={formData.phone} onChange={(e) => setFormData({ ...formData, phone: e.target.value })} placeholder="+91 98765 43210" className="w-full px-3 py-2 bg-dark-900 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                          </div>
                        </div>
                        <div>
                          <label className="block text-xs font-medium text-gray-400 mb-1.5">Location *</label>
                          <input type="text" value={formData.location} onChange={(e) => setFormData({ ...formData, location: e.target.value })} placeholder="Mumbai, Maharashtra" className="w-full px-3 py-2 bg-dark-900 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                        </div>
                        <div className="grid grid-cols-3 gap-3">
                          <div>
                            <label className="block text-xs font-medium text-gray-400 mb-1.5">LinkedIn</label>
                            <input type="text" value={formData.linkedin} onChange={(e) => setFormData({ ...formData, linkedin: e.target.value })} placeholder="linkedin.com/in/..." className="w-full px-3 py-2 bg-dark-900 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                          </div>
                          <div>
                            <label className="block text-xs font-medium text-gray-400 mb-1.5">GitHub</label>
                            <input type="text" value={formData.github} onChange={(e) => setFormData({ ...formData, github: e.target.value })} placeholder="github.com/..." className="w-full px-3 py-2 bg-dark-900 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                          </div>
                          <div>
                            <label className="block text-xs font-medium text-gray-400 mb-1.5">Portfolio</label>
                            <input type="text" value={formData.portfolio} onChange={(e) => setFormData({ ...formData, portfolio: e.target.value })} placeholder="yoursite.com" className="w-full px-3 py-2 bg-dark-900 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                          </div>
                        </div>
                      </>
                    )}

                    {/* Professional Summary */}
                    {id === 'summary' && (
                      <div>
                        <label className="block text-xs font-medium text-gray-400 mb-1.5">Summary</label>
                        <textarea value={formData.professionalSummary} onChange={(e) => setFormData({ ...formData, professionalSummary: e.target.value })} placeholder="Brief summary of your professional background..." rows={5} className="w-full px-3 py-2 bg-dark-900 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none resize-none" />
                      </div>
                    )}

                    {/* Skills */}
                    {id === 'skills' && (
                      <>
                        <div>
                          <label className="block text-xs font-medium text-gray-400 mb-1.5">Technical Skills (comma separated)</label>
                          <textarea value={formData.technicalSkills} onChange={(e) => setFormData({ ...formData, technicalSkills: e.target.value })} placeholder="Java, Spring Boot, MySQL, Docker..." rows={3} className="w-full px-3 py-2 bg-dark-900 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none resize-none" />
                        </div>
                        <div>
                          <label className="block text-xs font-medium text-gray-400 mb-1.5">Soft Skills (comma separated)</label>
                          <textarea value={formData.softSkills} onChange={(e) => setFormData({ ...formData, softSkills: e.target.value })} placeholder="Leadership, Communication, Problem Solving..." rows={2} className="w-full px-3 py-2 bg-dark-900 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none resize-none" />
                        </div>
                      </>
                    )}

                    {/* Experience */}
                    {id === 'experience' && (
                      <div className="space-y-4">
                        {formData.experiences.map((exp, idx) => (
                          <div key={idx} className="p-4 bg-dark-900 border border-white/10 rounded-lg space-y-3">
                            <div className="flex items-center justify-between">
                              <span className="text-xs text-gray-400 font-medium">Experience {idx + 1}</span>
                              {formData.experiences.length > 1 && (
                                <button onClick={() => removeExperience(idx)} className="text-red-400 hover:text-red-300">
                                  <Trash2 className="w-3.5 h-3.5" />
                                </button>
                              )}
                            </div>
                            <input type="text" value={exp.company} onChange={(e) => updateExperience(idx, 'company', e.target.value)} placeholder="Company Name" className="w-full px-3 py-2 bg-dark-800 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                            <input type="text" value={exp.role} onChange={(e) => updateExperience(idx, 'role', e.target.value)} placeholder="Role / Position" className="w-full px-3 py-2 bg-dark-800 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                            <input type="text" value={exp.duration} onChange={(e) => updateExperience(idx, 'duration', e.target.value)} placeholder="Jan 2022 – Present" className="w-full px-3 py-2 bg-dark-800 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                            <textarea value={exp.responsibilities} onChange={(e) => updateExperience(idx, 'responsibilities', e.target.value)} placeholder="Responsibilities (one per line)&#10;Led development of...&#10;Improved performance by 40%" rows={4} className="w-full px-3 py-2 bg-dark-800 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none resize-none" />
                          </div>
                        ))}
                        <button onClick={addExperience} className="flex items-center gap-1.5 px-3 py-2 bg-neon-blue/10 text-neon-blue border border-neon-blue/20 rounded-lg hover:bg-neon-blue/20 transition-colors text-sm">
                          <Plus className="w-3.5 h-3.5" /> Add Experience
                        </button>
                      </div>
                    )}

                    {/* Projects */}
                    {id === 'projects' && (
                      <div className="space-y-4">
                        {formData.projects.map((proj, idx) => (
                          <div key={idx} className="p-4 bg-dark-900 border border-white/10 rounded-lg space-y-3">
                            <div className="flex items-center justify-between">
                              <span className="text-xs text-gray-400 font-medium">Project {idx + 1}</span>
                              {formData.projects.length > 1 && (
                                <button onClick={() => removeProject(idx)} className="text-red-400 hover:text-red-300">
                                  <Trash2 className="w-3.5 h-3.5" />
                                </button>
                              )}
                            </div>
                            <input type="text" value={proj.name} onChange={(e) => updateProject(idx, 'name', e.target.value)} placeholder="Project Name" className="w-full px-3 py-2 bg-dark-800 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                            <textarea value={proj.description} onChange={(e) => updateProject(idx, 'description', e.target.value)} placeholder="Description and key achievements..." rows={3} className="w-full px-3 py-2 bg-dark-800 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none resize-none" />
                            <input type="text" value={proj.technologies} onChange={(e) => updateProject(idx, 'technologies', e.target.value)} placeholder="Technologies (e.g., Java, Spring Boot, MySQL)" className="w-full px-3 py-2 bg-dark-800 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                          </div>
                        ))}
                        <button onClick={addProject} className="flex items-center gap-1.5 px-3 py-2 bg-neon-blue/10 text-neon-blue border border-neon-blue/20 rounded-lg hover:bg-neon-blue/20 transition-colors text-sm">
                          <Plus className="w-3.5 h-3.5" /> Add Project
                        </button>
                      </div>
                    )}

                    {/* Education */}
                    {id === 'education' && (
                      <div className="space-y-4">
                        {formData.educations.map((edu, idx) => (
                          <div key={idx} className="p-4 bg-dark-900 border border-white/10 rounded-lg space-y-3">
                            <div className="flex items-center justify-between">
                              <span className="text-xs text-gray-400 font-medium">Education {idx + 1}</span>
                              {formData.educations.length > 1 && (
                                <button onClick={() => removeEducation(idx)} className="text-red-400 hover:text-red-300">
                                  <Trash2 className="w-3.5 h-3.5" />
                                </button>
                              )}
                            </div>
                            <input type="text" value={edu.degree} onChange={(e) => updateEducation(idx, 'degree', e.target.value)} placeholder="B.Tech in Computer Science" className="w-full px-3 py-2 bg-dark-800 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                            <input type="text" value={edu.institute} onChange={(e) => updateEducation(idx, 'institute', e.target.value)} placeholder="Institute Name" className="w-full px-3 py-2 bg-dark-800 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                            <div className="grid grid-cols-2 gap-3">
                              <input type="text" value={edu.year} onChange={(e) => updateEducation(idx, 'year', e.target.value)} placeholder="Year (e.g. 2022)" className="w-full px-3 py-2 bg-dark-800 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                              <input type="text" value={edu.gpa || ''} onChange={(e) => updateEducation(idx, 'gpa', e.target.value)} placeholder="GPA (optional)" className="w-full px-3 py-2 bg-dark-800 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none" />
                            </div>
                          </div>
                        ))}
                        <button onClick={addEducation} className="flex items-center gap-1.5 px-3 py-2 bg-neon-blue/10 text-neon-blue border border-neon-blue/20 rounded-lg hover:bg-neon-blue/20 transition-colors text-sm">
                          <Plus className="w-3.5 h-3.5" /> Add Education
                        </button>
                      </div>
                    )}

                    {/* Certifications */}
                    {id === 'certifications' && (
                      <div>
                        <label className="block text-xs font-medium text-gray-400 mb-1.5">Certifications (comma separated)</label>
                        <textarea value={formData.certifications} onChange={(e) => setFormData({ ...formData, certifications: e.target.value })} placeholder="AWS Certified Developer, CKA, Oracle Java SE 11..." rows={3} className="w-full px-3 py-2 bg-dark-900 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none resize-none" />
                      </div>
                    )}

                    {/* ATS */}
                    {id === 'ats' && (
                      <div className="space-y-4">
                        <div>
                          <label className="block text-xs font-medium text-gray-400 mb-1.5">Paste Job Description (optional)</label>
                          <textarea value={formData.jobDescription} onChange={(e) => { setFormData({ ...formData, jobDescription: e.target.value }); setAtsScore(null); }} placeholder="Paste the target job description here to calculate ATS compatibility..." rows={6} className="w-full px-3 py-2 bg-dark-900 border border-white/10 rounded-lg text-white text-sm focus:border-neon-blue focus:outline-none resize-none" />
                        </div>
                        {formData.jobDescription.trim() && (
                          <button onClick={handleCalculateATS} disabled={isCalculating} className="flex items-center gap-2 px-4 py-2 bg-neon-blue text-black font-semibold rounded-lg hover:bg-neon-blue/90 transition-colors disabled:opacity-60 text-sm">
                            {isCalculating ? <Loader2 className="w-4 h-4 animate-spin" /> : <CheckCircle className="w-4 h-4" />}
                            {isCalculating ? 'Calculating...' : 'Calculate ATS Score'}
                          </button>
                        )}
                        {atsScore && (
                          <div className="bg-dark-900 border border-white/10 rounded-lg p-4">
                            <div className="text-center mb-4">
                              <div className={`text-4xl font-bold ${getScoreColor(atsScore.total)}`}>{atsScore.total}/100</div>
                              <p className="text-gray-400 text-sm mt-1">
                                {atsScore.total >= 70 ? 'Excellent! ATS-friendly resume' : atsScore.total >= 50 ? 'Good — some improvements possible' : 'Needs improvement'}
                              </p>
                            </div>
                            <div className="space-y-2 text-sm">
                              {[
                                { label: 'Keywords Match', value: atsScore.keywordsMatch, max: 40 },
                                { label: 'Skills Alignment', value: atsScore.skillsAlignment, max: 30 },
                                { label: 'Experience Alignment', value: atsScore.experienceAlignment, max: 20 },
                                { label: 'ATS-Safe Formatting', value: atsScore.formatting, max: 10 },
                              ].map(({ label, value, max }) => (
                                <div key={label} className="flex items-center justify-between">
                                  <span className="text-gray-400">{label}</span>
                                  <span className="text-white font-semibold">{value}/{max}</span>
                                </div>
                              ))}
                            </div>
                          </div>
                        )}
                      </div>
                    )}
                  </div>
                )}
              </div>
            );
          })}
        </div>

        {/* ── RIGHT: Live Resume Preview ── */}
        <div className="bg-dark-800 border border-white/10 rounded-xl overflow-hidden sticky top-6">
          <div className="px-5 py-3 border-b border-white/10 flex items-center gap-2">
            <FileText className="w-4 h-4 text-neon-blue" />
            <span className="text-white font-medium text-sm">Live Preview</span>
            <span className="ml-auto text-xs text-gray-500">Updates as you type</span>
          </div>

          <div className="max-h-[780px] overflow-y-auto">
            <div className="bg-white text-black p-8 space-y-4 min-h-[400px]">
              {/* Header */}
              {formData.fullName ? (
                <div className="text-center border-b-2 border-gray-300 pb-4">
                  <h1 className="text-2xl font-bold text-black">{formData.fullName}</h1>
                  <p className="text-sm text-gray-600 mt-1">
                    {[formData.email, formData.phone, formData.location].filter(Boolean).join(' | ')}
                  </p>
                  {(formData.linkedin || formData.github || formData.portfolio) && (
                    <p className="text-xs text-gray-600 mt-1">
                      {[formData.linkedin, formData.github, formData.portfolio].filter(Boolean).join(' | ')}
                    </p>
                  )}
                </div>
              ) : (
                <div className="text-center border-b-2 border-gray-200 pb-4">
                  <div className="h-6 bg-gray-100 rounded w-48 mx-auto mb-2" />
                  <div className="h-3 bg-gray-100 rounded w-72 mx-auto" />
                </div>
              )}

              {/* Professional Summary */}
              {formData.professionalSummary && (
                <div>
                  <h2 className="text-sm font-bold border-b border-gray-400 mb-2 uppercase tracking-wide">Professional Summary</h2>
                  <p className="text-xs text-gray-800 leading-relaxed">{formData.professionalSummary}</p>
                </div>
              )}

              {/* Technical Skills */}
              {formData.technicalSkills && (
                <div>
                  <h2 className="text-sm font-bold border-b border-gray-400 mb-2 uppercase tracking-wide">Technical Skills</h2>
                  <p className="text-xs text-gray-800">{formData.technicalSkills}</p>
                </div>
              )}

              {/* Soft Skills */}
              {formData.softSkills && (
                <div>
                  <h2 className="text-sm font-bold border-b border-gray-400 mb-2 uppercase tracking-wide">Soft Skills</h2>
                  <p className="text-xs text-gray-800">{formData.softSkills}</p>
                </div>
              )}

              {/* Experience */}
              {formData.experiences.some((e) => e.company) && (
                <div>
                  <h2 className="text-sm font-bold border-b border-gray-400 mb-2 uppercase tracking-wide">Professional Experience</h2>
                  {formData.experiences.map((exp, i) =>
                    exp.company ? (
                      <div key={i} className="mb-3">
                        <p className="font-bold text-xs">{exp.role}{exp.company ? ` — ${exp.company}` : ''}</p>
                        {exp.duration && <p className="text-xs text-gray-500 italic">{exp.duration}</p>}
                        {exp.responsibilities && (
                          <ul className="list-disc list-inside text-xs text-gray-800 mt-1 space-y-0.5">
                            {exp.responsibilities.split('\n').map((b, bi) =>
                              b.trim() ? <li key={bi}>{b.replace(/^[-•]\s*/, '').trim()}</li> : null
                            )}
                          </ul>
                        )}
                      </div>
                    ) : null
                  )}
                </div>
              )}

              {/* Projects */}
              {formData.projects.some((p) => p.name) && (
                <div>
                  <h2 className="text-sm font-bold border-b border-gray-400 mb-2 uppercase tracking-wide">Projects</h2>
                  {formData.projects.map((proj, i) =>
                    proj.name ? (
                      <div key={i} className="mb-2">
                        <p className="font-bold text-xs">{proj.name}</p>
                        {proj.description && <p className="text-xs text-gray-800">{proj.description}</p>}
                        {proj.technologies && <p className="text-xs text-gray-500 italic">Technologies: {proj.technologies}</p>}
                      </div>
                    ) : null
                  )}
                </div>
              )}

              {/* Education */}
              {formData.educations.some((e) => e.degree) && (
                <div>
                  <h2 className="text-sm font-bold border-b border-gray-400 mb-2 uppercase tracking-wide">Education</h2>
                  {formData.educations.map((edu, i) =>
                    edu.degree ? (
                      <div key={i} className="mb-1.5">
                        <p className="font-bold text-xs">{edu.degree}{edu.institute ? ` — ${edu.institute}` : ''}{edu.year ? ` (${edu.year})` : ''}</p>
                        {edu.gpa && <p className="text-xs text-gray-600">GPA: {edu.gpa}</p>}
                      </div>
                    ) : null
                  )}
                </div>
              )}

              {/* Certifications */}
              {formData.certifications && (
                <div>
                  <h2 className="text-sm font-bold border-b border-gray-400 mb-2 uppercase tracking-wide">Certifications</h2>
                  <p className="text-xs text-gray-800">{formData.certifications}</p>
                </div>
              )}

              {/* Empty state */}
              {!formData.fullName && !formData.professionalSummary && (
                <div className="flex flex-col items-center justify-center py-16 text-center">
                  <FileText className="w-12 h-12 text-gray-200 mb-3" />
                  <p className="text-gray-400 text-sm">Fill in the sections on the left to see your resume here</p>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};

export default ResumeBuilder;
